# Database (Neon / Vercel Postgres)
DATABASE_URL=

# Auth.js
AUTH_SECRET=
AUTH_URL=https://your-deployment.vercel.app

# First admin user (postbuild seed, idempotent)
ADMIN_SEED_EMAIL=
ADMIN_SEED_PASSWORD=

# Gmail SMTP (lead + privacy request notifications)
GMAIL_USER=
GMAIL_APP_PASSWORD=
LEAD_NOTIFICATION_EMAIL=

# Optional: Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Optional Firebase override for PDF (default is public/pdf/CercaLabs_WP1.pdf)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=cercalabs-whitepaper.firebasestorage.app
